# ==============================================================
# Aurora Bot — Configuration Template
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to a public repository!
# ==============================================================

# --------------------------------------------------------------
# Discord
# --------------------------------------------------------------

# Bot token from the Discord Developer Portal
DISCORD_TOKEN=your_discord_bot_token_here

# Discord user ID of the server owner
# How to get it: Settings > Advanced > enable Developer Mode,
# then right-click your profile > Copy User ID
OWNER_ID=your_discord_user_id_here

# Command prefix (default: !)
COMMAND_PREFIX=!

# --------------------------------------------------------------
# Database
# --------------------------------------------------------------

# Path to the SQLite database file
DB_PATH=aurora.db

# --------------------------------------------------------------
# Ollama (Text Engine)
# --------------------------------------------------------------

# Model to use with Ollama
# Examples: qwen2.5, llama3.1, mistral, gemma2, phi3
OLLAMA_MODEL=qwen2.5

# --------------------------------------------------------------
# System Prompts
# Customize Aurora's personality and how she treats the owner.
# These values are stored in the database on first user interaction.
# --------------------------------------------------------------

DEFAULT_SYSTEM_PROMPT=You are Aurora, a friendly and helpful AI assistant. Answer clearly and concisely.

OWNER_SYSTEM_PROMPT=You are talking to the server owner. Treat them with respect and be direct.

# --------------------------------------------------------------
# Fooocus API (Image Engine)
# --------------------------------------------------------------

# SDXL model to use (exact .safetensors filename)
FOOOCUS_BASE_MODEL=realisticStockPhoto_v20.safetensors

# Refiner model — set to None to disable
FOOOCUS_REFINER_MODEL=None

# Comma-separated style presets
# Examples: Fooocus V2, Fooocus Enhance, SAI Photographic, MRE Cinematic Dynamic
FOOOCUS_STYLE=Fooocus V2,Fooocus Enhance

# Performance profile: Speed | Quality | Extreme Speed
FOOOCUS_PERFORMANCE=Speed

# Output image resolution (width*height)
# Examples: 1152*896 (landscape), 896*1152 (portrait), 1024*1024 (square)
FOOOCUS_ASPECT_RATIO=1152*896

# CFG / guidance scale — how closely the model follows the prompt
FOOOCUS_GUIDANCE_SCALE=7.0

# Sharpness (1.0 – 30.0)
FOOOCUS_SHARPNESS=2.0
